# DeveloperOS API environment (Phase 1).
# Copy to `apps/api/.env` and adjust values. This file is validated at startup
# by packages/config; missing or invalid values cause a fail-fast exit.

# Runtime environment: development | test | production
NODE_ENV=development

# Port the API HTTP server binds to.
PORT=4000

# PostgreSQL connection string. Matches the docker-compose service defaults.
DATABASE_URL=postgresql://developeros:developeros@localhost:5432/developeros_dev

# JWT signing secrets. Each must be at least 32 characters and the two MUST
# differ. Generate strong values, e.g. `openssl rand -base64 48`.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret-value
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret

# Comma-separated list of allowed CORS origins for the web client.
CORS_ORIGINS=http://localhost:3000
