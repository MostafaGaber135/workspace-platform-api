// DeveloperOS — Prisma schema.
//
// Phase 1 established identity and workspace containment (User, Workspace,
// WorkspaceMember). Phase 2 · Sprint 2 · Epic 1 adds the Workspace vertical
// slice: case-insensitive per-owner name uniqueness via `normalizedName`, and a
// minimal append-only AuditLog for workspace create/rename. Repositories,
// analysis sessions, suggestions, work logs, exports, Git, and AI remain out of
// scope.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Workspace membership role.
///
/// The default is MEMBER: creating a membership without an explicit role must
/// never grant elevated access. When a workspace owner membership is created,
/// OWNER is assigned explicitly (Architecture Addendum §1).
enum Role {
  OWNER
  MEMBER
}

/// Auditable workspace actions recorded in {@link AuditLog}. Kept intentionally
/// small for this epic — only workspace create and rename are audited.
enum AuditAction {
  WORKSPACE_CREATED
  WORKSPACE_RENAMED
}

/// An authenticated account. The password hash is stored here; it is never
/// exposed through any API response type (see shared-types `AuthenticatedUser`).
///
/// Email normalization strategy (PRD §12.2, §7.1):
///  - `email` retains the address exactly as entered (trimmed), for display.
///  - `normalizedEmail` is the canonical lookup key, derived by every create and
///    lookup path via `normalizeEmail()` (`email.trim().toLowerCase()`) in
///    `@developeros/validation`.
/// Case-insensitive uniqueness is enforced by the `@unique` constraint on
/// `normalizedEmail`. This deliberately avoids a functional `lower(email)` index
/// so the Prisma schema and migrations stay fully aligned with NO intentional
/// drift.
model User {
  id              String   @id @default(cuid())
  email           String
  normalizedEmail String   @unique
  passwordHash    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// Workspaces this user owns.
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  /// Membership rows linking this user into workspaces.
  workspaceMembers WorkspaceMember[]
  /// Audit records for which this user was the actor (append-only).
  auditLogs        AuditLog[]

  @@map("users")
}

/// Top-level isolation boundary. Every downstream resource (added in later
/// phases) is scoped to exactly one workspace.
///
/// Name uniqueness is per owner and CASE-INSENSITIVE: `name` retains the
/// user-facing trimmed value, while `normalizedName` (`name.trim().toLowerCase()`,
/// derived via `normalizeWorkspaceName()` in `@developeros/validation`) is the
/// canonical key. The `@@unique([ownerId, normalizedName])` constraint enforces
/// it with a plain composite index — no functional index, no schema drift.
/// `normalizedName` is internal and is never returned in API responses.
model Workspace {
  id             String   @id @default(cuid())
  name           String
  normalizedName String
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner     User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   WorkspaceMember[]
  auditLogs AuditLog[]

  @@unique([ownerId, normalizedName])
  @@map("workspaces")
}

/// Explicit join entity between User and Workspace carrying the membership
/// role. A user may belong to a workspace at most once, enforced by the unique
/// composite constraint. `role` defaults to MEMBER; OWNER is assigned explicitly.
model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

/// Append-only audit trail for workspace mutations.
///
/// Records are immutable and must survive future user/workspace deletion, so the
/// relations use `onDelete: Restrict` (NOT Cascade) until a formal deletion
/// policy is designed. Snapshots use explicit, non-sensitive fields only:
///  - WORKSPACE_CREATED: beforeSnapshot = null, afterSnapshot = created workspace
///    (approved public fields only — never `normalizedName`, secrets, headers,
///    or tokens).
///  - WORKSPACE_RENAMED: beforeSnapshot = { name: <previous> },
///    afterSnapshot = { name: <new> }.
model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  workspaceId    String
  actorId        String
  beforeSnapshot Json?
  afterSnapshot  Json?
  createdAt      DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  actor     User      @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([actorId])
  @@map("audit_logs")
}
