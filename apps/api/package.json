{
  "name": "@developeros/api",
  "version": "0.1.0",
  "private": true,
  "description": "DeveloperOS API — NestJS backend (Phase 1 foundation).",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "jest --config jest.config.ts",
    "test:e2e": "jest --config jest-e2e.config.ts --runInBand",
    "test:integration": "jest --config jest-integration.config.ts --runInBand",
    "clean": "rm -rf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@developeros/config": "workspace:*",
    "@developeros/shared-types": "workspace:*",
    "@developeros/validation": "workspace:*",
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/swagger": "8.1.0",
    "@node-rs/argon2": "2.0.2",
    "@prisma/client": "5.22.0",
    "dotenv": "16.4.7",
    "jsonwebtoken": "9.0.2",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.15",
    "@types/express": "5.0.0",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.17.10",
    "@types/supertest": "6.0.2",
    "eslint": "9.17.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.6.3"
  }
}
